# Copy to .env — no trailing slash on URLs.
#
# ── Local dev with Vite proxy (recommended) ─────────────────────────────
# Leave all VITE_* empty (or delete them). The app uses same-origin `/api/...`
# and vite.config.ts proxies to:
#   /api/auth         → http://localhost:8081
#   /api/users        → http://localhost:8081
#   /api/matchmaking  → http://localhost:8082
#   /api/game         → http://localhost:8083
#   /api/battle       → http://localhost:8084
#   /api/analytics    → http://localhost:8080
#
# VITE_AUTH_URL=
# VITE_MATCHMAKING_URL=
# VITE_GAME_URL=
# VITE_BATTLE_URL=
# VITE_ANALYTICS_URL=
#
# ── Direct URLs (CORS must allow the front-end origin) ───────────────────
VITE_AUTH_URL=http://localhost:8081
VITE_MATCHMAKING_URL=http://localhost:8082
VITE_GAME_URL=http://localhost:8083
VITE_BATTLE_URL=http://localhost:8084
VITE_ANALYTICS_URL=http://localhost:8080
